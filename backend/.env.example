# =================================
# SaferCloud Backend Environment Variables
# Copy this file to .env and fill in your values
# =================================

# ===== DATABASE =====
DATABASE_URL=postgres://user:password@localhost:5432/safercloud?sslmode=disable

# ===== REDIS =====
REDIS_URL=redis://localhost:6379

# ===== JWT / SUPABASE =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# ===== S3 STORAGE =====
S3_ENDPOINT=s3.amazonaws.com
S3_BUCKET=safercloud-bucket
S3_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== BILLING (Optional - External Service) =====
# Configure these to connect to an external billing service (e.g., SaferCloud-Billing)
# If not configured, the app uses MockProvider with a free 5GB plan
#
# URL of your billing service API
# BILLING_SERVICE_URL=https://billing.your-domain.com
#
# Shared secret for HMAC signature verification (generate a random 64-char hex string)
# BILLING_SERVICE_SECRET=your-64-char-hex-secret

# ===== P2P / TURN Server (Optional) =====
# TURN_SERVER_URL=turn:turn.your-domain.com:3478
# TURN_USERNAME=your-turn-username
# TURN_CREDENTIAL=your-turn-credential
