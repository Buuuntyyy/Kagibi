# =================================
# SaferCloud Backend Environment Variables
# Copy this file to .env and fill in your values
# =================================

# ===== AUTH PROVIDER =====
# "local" (default) — Go backend + PostgreSQL, no external service required
# "supabase" — Supabase/GoTrue
# "pocketbase" — PocketBase
AUTH_PROVIDER=local

# ===== JWT (required when AUTH_PROVIDER=local) =====
JWT_SECRET=change-me-use-a-long-random-string

# ===== DATABASE =====
DATABASE_URL=postgres://user:password@localhost:5432/safercloud?sslmode=disable

# ===== REDIS =====
REDIS_URL=redis://localhost:6379

# ===== SUPABASE AUTH (required when AUTH_PROVIDER=supabase) =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
# Admin key for user management (register cleanup, recovery, RGPD deletion)
# SUPABASE_ADMIN_KEY=your-service-role-key

# ===== POCKETBASE AUTH (only when AUTH_PROVIDER=pocketbase) =====
# POCKETBASE_URL=http://localhost:8090
# POCKETBASE_ADMIN_EMAIL=admin@safercloud.local
# POCKETBASE_ADMIN_PASSWORD=your-admin-password
# POCKETBASE_JWT_SECRET=your-32-char-minimum-secret

# ===== S3 STORAGE =====
S3_ENDPOINT=s3.amazonaws.com
S3_BUCKET=safercloud-bucket
S3_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== BILLING =====
# Set to "false" to disable billing completely (self-hosted unlimited mode)
BILLING_ENABLED=true
# BILLING_SERVICE_URL=https://billing.your-domain.com
# BILLING_SERVICE_SECRET=your-64-char-hex-secret

# ===== P2P / TURN Server (Optional) =====
# TURN_SERVER_URL=turn:turn.your-domain.com:3478
# TURN_USERNAME=your-turn-username
# TURN_CREDENTIAL=your-turn-credential
