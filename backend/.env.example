# =================================
# SaferCloud Backend Environment Variables
# Copy this file to .env and fill in your values
# =================================

# ===== DATABASE =====
DATABASE_URL=postgres://user:password@localhost:5432/safercloud?sslmode=disable

# ===== REDIS =====
REDIS_URL=redis://localhost:6379

# ===== JWT / SUPABASE =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# ===== S3 STORAGE =====
S3_ENDPOINT=s3.amazonaws.com
S3_BUCKET=safercloud-bucket
S3_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== BILLING - LAGO =====
# Lago API URL (self-hosted or cloud)
LAGO_API_URL=https://api.getlago.com
# Lago API Key from your Lago dashboard
LAGO_API_KEY=your-lago-api-key
# Webhook secret for verifying Lago webhook signatures
LAGO_WEBHOOK_SECRET=your-lago-webhook-secret
# Buffer size for usage events (default: 100)
LAGO_BUFFER_SIZE=100
# Flush interval in seconds (default: 30)
LAGO_FLUSH_INTERVAL_SECONDS=30

# ===== BILLING - MOLLIE =====
# Mollie API Key (test or live)
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook URL for Mollie payment status updates (public URL)
MOLLIE_WEBHOOK_URL=https://your-domain.com/api/v1/webhooks/mollie
# Redirect URL after payment completion
MOLLIE_REDIRECT_URL=https://your-domain.com/dashboard/billing
# Set to "true" for test mode
MOLLIE_TEST_MODE=true

# ===== BILLING - GENERAL =====
# Set to "true" to use MockPaymentProvider instead of Mollie
BILLING_TEST_MODE=true
# Redirect URL after payment (used in Lago webhook handler)
BILLING_REDIRECT_URL=https://your-domain.com/dashboard/billing
