# =============================================================
# Kagibi — Configuration auto-hébergement
# Copiez ce fichier : cp .env.example .env
# Remplissez les valeurs marquées REQUIRED avant de lancer
# docker compose up -d
# =============================================================

# ===== REQUIRED — Sécurité =====

# Clé secrète JWT (générez avec : openssl rand -hex 32)
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# Clé AES-256 pour le chiffrement des emails au repos
# ATTENTION : ne jamais changer après la première utilisation (les emails existants deviendraient illisibles)
# Générez avec : openssl rand -hex 32
EMAIL_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32

# ===== REQUIRED — Stockage S3 =====
# Compatible AWS S3, OVH Object Storage, Scaleway, Cloudflare R2, MinIO…

S3_ENDPOINT=https://s3.par.io.cloud.ovh.net
S3_BUCKET=bucket-name
S3_REGION=par
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# ===== REQUIRED — URLs =====

# URL que le navigateur utilise pour atteindre le backend
# En local :        http://localhost:8080/api/v1
# En production :   https://your-domain.com/api/v1
VITE_API_URL=http://localhost:8080/api/v1

# Origines CORS autorisées — doit correspondre à l'URL du frontend
# En local :        http://localhost
# En production :   https://your-domain.com
ALLOWED_ORIGINS=http://localhost

# ===== Base de données =====
# Mot de passe PostgreSQL (l'utilisateur et la base sont créés automatiquement)
DB_PASSWORD=postgres

# ===== Authentification =====
# "local"      — Go backend + PostgreSQL, aucun service externe requis (recommandé)
# "supabase"   — Supabase/GoTrue
# "pocketbase" — PocketBase
AUTH_PROVIDER=local

# ===== Billing =====
# false = stockage illimité, aucune UI billing (recommandé pour l'auto-hébergement)
# true  = active les limites de plan (dev/mock par défaut, Stripe en production)
BILLING_ENABLED=false

# ===== P2P / TURN (optionnel) =====
# Requis uniquement pour le transfert P2P entre appareils derrière NAT strict
# TURN_SERVER_URL=turn:turn.your-domain.com:3478
# TURN_USERNAME=username
# TURN_CREDENTIAL=password

# ===== Google Drive Import (optionnel) =====
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ===== Ports (optionnel) =====
# FRONTEND_PORT=80
# BACKEND_PORT=8080
