# IMPORTANT: This is a template file for Kubernetes secrets.
#
# DO NOT commit the real secrets.yaml file to git!
#
# Instructions:
# 1. Copy this file to secrets.yaml
# 2. Run k8s/scripts/encode-secrets.sh (Linux/macOS) or encode-secrets.ps1 (Windows)
# 3. Replace the base64 values below with the output from the script
# 4. Update your Lago and Mollie keys with your actual values
# 5. Apply to cluster: kubectl apply -f k8s/security/secrets.yaml
#
# To manually encode a value:
#   Linux/macOS: echo -n 'your-value' | base64
#   PowerShell:  [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes('your-value'))

apiVersion: v1
kind: Secret
metadata:
  name: safercloud-secrets
  namespace: safercloud
type: Opaque
data:
  # Database Configuration (Supabase PostgreSQL - base64 encoded)
  # Format: postgresql://user:pass@host:port/db
  DATABASE_URL: <base64-encoded-database-url>

  # Redis Configuration (Upstash - base64 encoded)
  REDIS_URL: <base64-encoded-redis-url>

  # Supabase Configuration (base64 encoded)
  SUPABASE_URL: <base64-encoded-supabase-url>
  SUPABASE_ANON_KEY: <base64-encoded-anon-key>
  SUPABASE_JWT_SECRET: <base64-encoded-jwt-secret>
  SUPABASE_SERVICE_ROLE_KEY: <base64-encoded-service-role-key>
  VITE_SUPABASE_ANON_KEY: <base64-encoded-anon-key>

  # S3 Storage (OVH - base64 encoded)
  S3_ACCESS_KEY: <base64-encoded-access-key>
  S3_SECRET_KEY: <base64-encoded-secret-key>

  # Billing - Lago (base64 encoded)
  LAGO_API_KEY: <base64-encoded-lago-api-key>
  LAGO_WEBHOOK_SECRET: <base64-encoded-lago-webhook-secret>

  # Billing - Mollie (base64 encoded)
  MOLLIE_API_KEY: <base64-encoded-mollie-api-key>
  MOLLIE_WEBHOOK_SECRET: <base64-encoded-mollie-webhook-secret>
