# =================================
# SaferCloud - Production Environment Variables
# =================================

# ===== PORTS =====
BACKEND_PORT=8080
FRONTEND_PORT=80
METRICS_PORT=9090
PROMETHEUS_PORT=9091
GRAFANA_PORT=3001

# ===== DATABASE (PostgreSQL) =====
# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=safercloud
DB_SSLMODE=disable
DATABASE_URL="postgresql_url"
SUPABASE_URL="supabase_url"
SUPABASE_ANON_KEY="anon_key"

# ===== REDIS =====
REDIS_URL="your_redis_url"

# ===== SUPABASE (Authentication) =====
SUPABASE_URL="supabase_url"
SUPABASE_JWT_SECRET="jwt_secret"

# ===== S3 STORAGE =====
# Replace following values with your S3-compatible storage configuration
S3_ENDPOINT=url_bucket_ovh
S3_REGION=bucket_region
S3_BUCKET=bucket_name
S3_ACCESS_KEY=access_key
S3_SECRET_KEY=secret_key

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:5173

# ===== FRONTEND RUNTIME VARIABLES =====
VITE_API_URL=your_api_url
VITE_SUPABASE_URL=supabase_url
VITE_SUPABASE_ANON_KEY=anon_key

# ===== BILLING =====
BILLING_ENABLED=false

# ===== MONITORING (Grafana) =====
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password
