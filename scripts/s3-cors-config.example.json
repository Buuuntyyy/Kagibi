{
  "CORSRules": [
    {
      "ID": "Kagibi-Multipart-Upload",
      "AllowedOrigins": [
        "https:://domain.com"
      ],
      "AllowedMethods": [
        "PUT",
        "POST",
        "GET",
        "HEAD",
        "DELETE"
      ],
      "AllowedHeaders": [
        "*"
      ],
      "ExposeHeaders": [
        "ETag",
        "x-amz-request-id",
        "x-amz-id-2"
      ],
      "MaxAgeSeconds": 3600
    }
  ]
}
