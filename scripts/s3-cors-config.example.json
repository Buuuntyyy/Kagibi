{
  "CORSRules": [
    {
      "ID": "Kagibi-Multipart-Upload",
      "AllowedOrigins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173",
        "http://localhost:3000"
      ],
      "AllowedMethods": [
        "PUT",
        "POST",
        "GET",
        "HEAD"
      ],
      "AllowedHeaders": [
        "*"
      ],
      "ExposeHeaders": [
        "ETag",
        "x-amz-request-id",
        "x-amz-id-2"
      ],
      "MaxAgeSeconds": 3600
    }
  ]
}
